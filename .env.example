# ─── HAR Environment Configuration ───

NODE_ENV=development

# PORTS
GATEWAY_PORT=4000
ORCHESTRATOR_PORT=4001
INTENT_SERVICE_PORT=4002
LOCAL_LLM_PORT=4003
CLOUD_LLM_PORT=4004
WEB_PORT=3000

# LOCAL LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Recommended models: llama3.2, phi3:mini
OLLAMA_MODEL=llama3.2

# CLOUD LLM (Optional)
# Supported providers: gemini, openai
CLOUD_PROVIDER=gemini
# Leave empty to run in LOCAL-only mode
CLOUD_API_KEY=
CLOUD_MODEL=gemini-2.0-flash

# POLICIES
LOCAL_TIMEOUT_MS=15000
CLOUD_TIMEOUT_MS=12000
MAX_RETRIES=1
ALLOW_CLOUD_FALLBACK=true
